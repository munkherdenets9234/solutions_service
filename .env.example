# Application
APP_ENV=development
APP_PORT=8080

# MongoDB
MONGO_URI=mongodb://eands_user:eands_pass@mongo:27017/eandstravel?authSource=admin
MONGO_DB=eandstravel
MONGO_USER=eands_user
MONGO_PASS=eands_pass

# Redis
REDIS_ADDR=redis:6379
REDIS_PASS=redis_secret

# Auth (must be at least 32 characters)
TOKEN_SECRET=change_this_to_a_very_long_random_secret_string
TOKEN_EXPIRY_HOURS=24

# Cloudinary (for image uploads)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Superadmin bootstrap — creates one platform user on startup if no account
# with this email exists yet. Leave blank to skip (e.g. once you already
# have a platform user and don't want a fixed password sitting in .env).
SUPERADMIN_NAME=Superadmin
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
